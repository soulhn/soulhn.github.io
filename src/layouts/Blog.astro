---
interface Props {
  title: string;
  description: string;
  active?: string;
}
const { title, description, active = '' } = Astro.props;
const tabs = [
  { key: '', label: '전체', href: '/blog/' },
  { key: 'build', label: '빌드 로그', href: '/blog/c/build/' },
  { key: 'learning', label: '학습 로그', href: '/blog/c/learning/' },
  { key: 'hobby', label: '취미', href: '/blog/c/hobby/' },
];
---
<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
<meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
<link rel="alternate" type="application/rss+xml" title="Log RSS" href="/rss.xml" />
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⚡</text></svg>" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" />
<style is:global>
  :root {
    --bg: #fafafa;
    --surface: #ffffff;
    --line: #e6e8ee;
    --ink: #1b1f27;
    --sub: #555d6b;
    --faint: #6f7889;
    --cyan: #0e7c9c;
    --violet: #5b46c4;
    --green: #0b7d54;
    --amber: #8a5f06;
    --mono: ui-monospace, "SF Mono", SFMono-Regular, Menlo, Consolas, monospace;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: "Pretendard Variable", Pretendard, -apple-system, BlinkMacSystemFont,
      "Apple SD Gothic Neo", "Noto Sans KR", system-ui, sans-serif;
    background: var(--bg); color: var(--ink);
    line-height: 1.75; font-size: 16.5px;
    -webkit-font-smoothing: antialiased;
    word-break: keep-all; overflow-wrap: break-word;
  }
  .wrap { max-width: 720px; margin: 0 auto; padding: 0 24px; }
  a { color: var(--cyan); text-decoration: none; }
  a:hover { text-decoration: underline; text-underline-offset: 3px; }
  ::selection { background: rgba(14,124,156,.18); }

  header.site { padding: 44px 0 8px; }
  .back { font-family: var(--mono); font-size: 12.5px; color: var(--faint); }
  .back:hover { color: var(--cyan); text-decoration: none; }
  h1.site-title { font-size: 26px; font-weight: 800; letter-spacing: -0.02em; margin-top: 10px; }
  .site-desc { font-size: 14px; color: var(--sub); margin-top: 4px; }

  nav.tabs { display: flex; gap: 8px; margin: 22px 0 36px; flex-wrap: wrap; }
  nav.tabs a {
    font-size: 13.5px; font-weight: 600; color: var(--sub);
    padding: 6px 14px; border: 1px solid var(--line); border-radius: 99px;
    background: var(--surface);
  }
  nav.tabs a:hover { border-color: var(--cyan); color: var(--cyan); text-decoration: none; }
  nav.tabs a.on { background: var(--ink); border-color: var(--ink); color: #fff; }

  footer.site {
    border-top: 1px solid var(--line); margin-top: 72px; padding: 24px 0 56px;
    font-size: 13px; color: var(--faint);
    display: flex; flex-wrap: wrap; gap: 6px 18px; justify-content: space-between;
  }
</style>
</head>
<body>
  <div class="wrap">
    <header class="site">
      <a class="back" href="/">← soulhn.github.io</a>
      <h1 class="site-title">Log</h1>
      <p class="site-desc">만들고 배운 것을 기록합니다.</p>
      <nav class="tabs">
        {tabs.map(t => <a href={t.href} class={active === t.key ? 'on' : ''}>{t.label}</a>)}
      </nav>
    </header>
    <slot />
    <footer class="site">
      <span>© 2026 황설현 · Sulhyeon Hwang</span>
      <span>Built with Claude Code · <a href="https://github.com/soulhn/soulhn.github.io" target="_blank" rel="noopener">Source</a></span>
    </footer>
  </div>
</body>
</html>
